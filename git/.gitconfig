[core]
    attributesFile = ~/.gitattributes
	pager = bat --paging=always
	editor = nvim

[diff "zip"]
    textconv = unzip -p
    binary = true
[diff "gz"]
    textconv = gzcat
    binary = true
[diff "bz2"]
    textconv = bzcat
    binary = true
[diff "xz"]
    textconv = xzcat
    binary = true
[diff "tar"]
    textconv = tar -O -xf
    binary = true
[diff "tar-bz2"]
    textconv = tar -O -xjf
    binary = true
[diff "tar-gz"]
    textconv = tar -O -xzf
    binary = true
[diff "tar-xz"]
    textconv = tar -O -xJf
    binary = true

[diff "odf"]
    textconv = odt2txt
[diff "pdf"]
    textconv = pdfinfo
[diff "bin"]
    textconv = hexdump -v -C

[init]
	defaultBranch = main
[color]
	ui = auto

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true

[merge]
    conflictstyle = zdiff3

[pull]
	rebase = true
[rebase]
	autoStash = true
[fetch]
	prune = true
[diff]
	tool = vimdiff

[include]
    path = ~/.gitconfig.local
